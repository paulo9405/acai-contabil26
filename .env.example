# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database - PostgreSQL (Production)
# Render automatically provides DATABASE_URL, these are for local PostgreSQL
USE_POSTGRES=True
DB_NAME=gestao_financeira
DB_USER=gestao_financeira_user
DB_PASSWORD=your-database-password-here
DB_HOST=localhost
DB_PORT=5432

# Database URL (Render provides this automatically as DATABASE_URL)
# No Render, não precisa configurar manualmente - é automático
# Para testes locais com PostgreSQL, descomente e configure:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Security Settings (Production - uncomment when deploying)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Email Configuration (Optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-app-password
