# ===========================================
# DJANGO CORE SETTINGS
# ===========================================

# Security
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# PRODUCTION (Render)
# Render provides DATABASE_URL automatically - DO NOT set manually
# RENDER=true (set automatically by Render)
# DATABASE_URL=postgresql://... (set automatically by Render)

# DEVELOPMENT - PostgreSQL Local
# Uncomment to use local PostgreSQL instead of SQLite
# USE_POSTGRES=True
# DB_NAME=gestao_financeira
# DB_USER=gestao_financeira_user
# DB_PASSWORD=your-database-password-here
# DB_HOST=localhost
# DB_PORT=5432

# DEVELOPMENT - SQLite (default)
# If USE_POSTGRES is not set, SQLite will be used automatically

# ===========================================
# SUPERUSER (Auto-created on first deploy)
# ===========================================

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# ===========================================
# SECURITY SETTINGS (Production)
# ===========================================

# These are enabled by default when DEBUG=False
# Uncomment only if you need to override defaults

# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-app-password
